# Slack Bot User OAuth Token (starts with xoxb-)
# Slack app → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (starts with xapp-) — required for Socket Mode
# Slack app → Basic Information → App-Level Tokens → Generate (scope: connections:write)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Only needed if you switch to HTTP mode (socketMode: false)
# Slack app → Basic Information → App Credentials → Signing Secret
# SLACK_SIGNING_SECRET=your-signing-secret

# Optional — port for HTTP mode
# PORT=3000
